# Конфигурация TwoSigma

# ==================== База данных ====================

# Тип БД: sqlite, postgresql, mysql
DB_TYPE=sqlite

# Для PostgreSQL/MySQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=twosigma
DB_USER=postgres
DB_PASSWORD=your_password_here

# Для SQLite (путь к файлу)
# SQLITE_PATH=data/twosigma.db

# ==================== Статистика ====================

# Уровень значимости (alpha): 0.01, 0.05, 0.1
SIGNIFICANCE_LEVEL=0.05

# Минимальный размер выборки
MIN_SAMPLE_SIZE=100

# ==================== Приложение ====================

# Порт Streamlit (опционально)
# STREAMLIT_SERVER_PORT=8501

# Режим отладки
# DEBUG=false
